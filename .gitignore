# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Editor and OS files
.DS_Store
.idea/
.vscode/

# Logs and temporary files
*.log
*.tmp
*.bak

# Local environment exports or secrets
.env
.env.*

# Large model checkpoints and generated weights
src/checkpoints/*.pth
src/checkpoints/*.pt
src/checkpoints/*.ckpt

# Keep the folders, ignore the files
data/**/*
!data/**/
!data/**/.gitkeep